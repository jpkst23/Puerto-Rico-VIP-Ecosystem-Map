<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Fraunces:wght@400;600;700&display=swap');
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0d1117;--surface:#161b22;--surface2:#21262d;--border:rgba(255,255,255,0.08);
  --text:#e6edf3;--muted:#8b949e;--accent:#f0b429;--green:#3fb950;
  --hover:rgba(240,180,41,0.15);--active:rgba(240,180,41,0.28);
  --r:14px;--rs:8px;--shadow:0 8px 40px rgba(0,0,0,0.5);
  --ease:all 0.35s cubic-bezier(0.4,0,0.2,1);
}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;overflow:hidden}

/* HEADER */
#hdr{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:10px 22px;background:rgba(13,17,23,0.88);backdrop-filter:blur(16px);border-bottom:1px solid var(--border)}
#hdr h1{font-family:'Fraunces',serif;font-size:1rem;font-weight:700;color:var(--accent);letter-spacing:0.01em}
#hdr p{font-size:0.68rem;color:var(--muted);margin-top:1px}
#back{display:none;align-items:center;gap:7px;background:var(--surface2);border:1px solid var(--border);color:var(--text);padding:6px 14px;border-radius:99px;font-size:0.76rem;font-weight:500;cursor:pointer;transition:var(--ease);font-family:inherit}
#back:hover{background:var(--hover);border-color:var(--accent)}
#back svg{width:13px;height:13px}

/* MAP */
#outer{position:fixed;top:52px;left:0;right:0;bottom:0;overflow:hidden}
#container{position:absolute;width:100%;height:100%;transform-origin:0 0;transition:transform 0.55s cubic-bezier(0.4,0,0.2,1)}
#mapimg{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:contain;pointer-events:none;display:block}
#slayer{position:absolute;top:0;left:0;width:100%;height:100%}

/* SECTOR REGIONS */
.sr{
  position:absolute;border-radius:var(--r);border:2px solid transparent;cursor:pointer;
  transition:background 0.22s ease,border-color 0.22s ease,box-shadow 0.22s ease;
}
.sr:hover{background:var(--hover);border-color:var(--accent);box-shadow:0 0 0 4px rgba(240,180,41,0.08),inset 0 0 24px rgba(240,180,41,0.04)}
.sr.active{background:var(--active);border-color:var(--accent);box-shadow:0 0 0 6px rgba(240,180,41,0.12)}

/* SIDEBAR */
#sb{
  position:fixed;top:52px;right:0;bottom:0;width:360px;max-width:90vw;
  background:var(--surface);border-left:1px solid var(--border);
  transform:translateX(100%);transition:transform 0.45s cubic-bezier(0.4,0,0.2,1);
  display:flex;flex-direction:column;z-index:50;overflow:hidden;
  box-shadow:-8px 0 40px rgba(0,0,0,0.4);
}
#sb.open{transform:translateX(0)}
#sb-head{padding:18px 18px 12px;border-bottom:1px solid var(--border);flex-shrink:0}
#sb-name{font-family:'Fraunces',serif;font-size:1.25rem;font-weight:700;color:var(--accent);line-height:1.2;margin-bottom:3px}
#sb-count{font-size:0.7rem;color:var(--muted)}
#sb-search{padding:10px 14px;flex-shrink:0;border-bottom:1px solid var(--border)}
#sb-search input{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:var(--rs);padding:7px 11px;color:var(--text);font-family:inherit;font-size:0.8rem;outline:none;transition:border-color 0.2s}
#sb-search input::placeholder{color:var(--muted)}
#sb-search input:focus{border-color:var(--accent)}
#alist{overflow-y:auto;flex:1;padding:10px;scrollbar-width:thin;scrollbar-color:var(--border) transparent}
#alist::-webkit-scrollbar{width:3px}
#alist::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}

/* ASSET CARDS */
.card{
  padding:12px 14px;border-radius:var(--rs);border:1px solid var(--border);
  margin-bottom:7px;cursor:pointer;transition:var(--ease);background:var(--surface2);
  animation:sli 0.28s ease both;position:relative;
}
.card:hover{border-color:rgba(240,180,41,0.4);background:rgba(240,180,41,0.04);transform:translateX(3px)}
.card.nolink{opacity:0.65;cursor:default}
.card.nolink:hover{transform:none;border-color:var(--border);background:var(--surface2)}
.cn{font-size:0.83rem;font-weight:600;color:var(--text);line-height:1.3;margin-bottom:2px}
.cd{font-size:0.7rem;color:var(--muted);line-height:1.4}
.has-notes{font-size:0.65rem;color:var(--green);margin-top:4px;display:flex;align-items:center;gap:4px}
.has-notes::before{content:"";width:5px;height:5px;border-radius:50%;background:var(--green);flex-shrink:0}
.clb{position:absolute;top:10px;right:10px;width:16px;height:16px;background:var(--green);border-radius:50%;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity 0.2s}
.clb svg{width:8px;height:8px;fill:#000}
.card:hover .clb{opacity:1}
@keyframes sli{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:translateY(0)}}

/* MODAL */
#mo{position:fixed;inset:0;z-index:200;background:rgba(0,0,0,0.65);backdrop-filter:blur(7px);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.3s;padding:20px}
#mo.vis{opacity:1;pointer-events:all}
#md{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:26px 26px 22px;max-width:500px;width:100%;box-shadow:var(--shadow);transform:translateY(18px) scale(0.97);transition:transform 0.3s cubic-bezier(0.4,0,0.2,1);position:relative;max-height:85vh;display:flex;flex-direction:column}
#mo.vis #md{transform:translateY(0) scale(1)}
#mc{position:absolute;top:12px;right:12px;width:26px;height:26px;border-radius:50%;background:var(--surface2);border:1px solid var(--border);cursor:pointer;color:var(--muted);display:flex;align-items:center;justify-content:center;transition:var(--ease);font-size:0.9rem}
#mc:hover{color:var(--accent);background:var(--hover)}
#mbadge{display:inline-flex;align-items:center;background:rgba(240,180,41,0.1);border:1px solid rgba(240,180,41,0.28);color:var(--accent);font-size:0.65rem;font-weight:600;padding:2px 9px;border-radius:99px;letter-spacing:0.05em;text-transform:uppercase;margin-bottom:9px;max-width:fit-content}
#mname{font-family:'Fraunces',serif;font-size:1.3rem;font-weight:700;line-height:1.25;margin-bottom:5px;color:var(--text);padding-right:28px}
#mdesc{font-size:0.78rem;color:var(--muted);margin-bottom:12px}
#mnotes-wrap{flex:1;overflow-y:auto;margin-bottom:16px;scrollbar-width:thin;scrollbar-color:var(--border) transparent}
#mnotes-wrap::-webkit-scrollbar{width:3px}
#mnotes-wrap::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
#mnotes{font-size:0.82rem;color:var(--text);line-height:1.7;background:var(--surface2);border:1px solid var(--border);border-radius:var(--rs);padding:13px 15px;white-space:pre-wrap}
#mact{flex-shrink:0;padding-top:14px;border-top:1px solid var(--border)}
#mlink{display:inline-flex;align-items:center;gap:7px;background:var(--accent);color:#000;font-weight:700;font-size:0.8rem;font-family:inherit;padding:9px 18px;border-radius:99px;text-decoration:none;transition:var(--ease)}
#mlink:hover{background:#ffc947;transform:translateY(-1px);box-shadow:0 4px 16px rgba(240,180,41,0.3)}
#mlink svg{width:12px;height:12px}
#mnolink{display:inline-flex;align-items:center;gap:7px;background:var(--surface2);color:var(--muted);font-size:0.8rem;padding:9px 18px;border-radius:99px;border:1px solid var(--border)}

/* LEGEND */
#leg{position:fixed;bottom:18px;left:18px;z-index:60;background:rgba(13,17,23,0.88);backdrop-filter:blur(12px);border:1px solid var(--border);border-radius:var(--r);padding:11px 14px;font-size:0.68rem;color:var(--muted);line-height:1.6;max-width:185px}
#leg strong{display:block;color:var(--text);font-size:0.72rem;margin-bottom:5px}
.tip{display:flex;align-items:flex-start;gap:5px;margin-bottom:2px}
.tip::before{content:"▸";color:var(--accent);flex-shrink:0}

/* TOAST */
#toast{position:fixed;bottom:18px;right:18px;z-index:300;background:var(--surface);border:1px solid var(--accent);color:var(--text);padding:9px 16px;border-radius:99px;font-size:0.75rem;font-weight:500;transform:translateY(55px);opacity:0;transition:all 0.32s cubic-bezier(0.4,0,0.2,1);pointer-events:none}
#toast.show{transform:translateY(0);opacity:1}

/* GROUP SECTOR VIEW */
#group-view{padding:14px 12px;display:none;flex-direction:column;gap:8px;overflow-y:auto;flex:1}
.group-desc{font-size:0.78rem;color:var(--muted);line-height:1.6;padding:0 2px 6px;border-bottom:1px solid var(--border);margin-bottom:4px}
.child-card{
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 16px;border-radius:var(--rs);border:1px solid var(--border);
  background:var(--surface2);cursor:pointer;transition:var(--ease);
  animation:sli 0.28s ease both;
}
.child-card:hover{border-color:rgba(240,180,41,0.5);background:rgba(240,180,41,0.06);transform:translateX(3px)}
.child-card-left{}
.child-card-name{font-size:0.88rem;font-weight:600;color:var(--text);margin-bottom:2px}
.child-card-count{font-size:0.68rem;color:var(--muted)}
.child-card-arrow{color:var(--accent);font-size:1rem;opacity:0.7;transition:opacity 0.2s,transform 0.2s}
.child-card:hover .child-card-arrow{opacity:1;transform:translateX(3px)}

@media(max-width:640px){
  #sb{width:100%;max-width:100%;top:auto;bottom:0;height:65vh;border-left:none;border-top:1px solid var(--border);transform:translateY(100%)}
  #sb.open{transform:translateY(0)}
  #leg{display:none}
}
</style>
