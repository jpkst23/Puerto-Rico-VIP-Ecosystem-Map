let active = null, curAssets = [], tmr;

// ═══════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════
function init() {
  const layer = document.getElementById('slayer');
  REGIONS.forEach(r => {
    const el = document.createElement('div');
    el.className = 'sr';
    el.setAttribute('data-key', r.key);
    el.style.cssText = `top:${r.top}%;left:${r.left}%;width:${r.width}%;height:${r.height}%`;
    el.addEventListener('click', () => openSector(r.key, el));
    layer.appendChild(el);
  });
}

// ═══════════════════════════════════════════════
// OPEN SECTOR
// ═══════════════════════════════════════════════
function openSector(key, el) {
  document.querySelectorAll('.sr').forEach(r => r.classList.remove('active'));
  if(el) el.classList.add('active');
  active = key;

  const alist = document.getElementById('alist');
  const gview = document.getElementById('group-view');
  const searchBar = document.getElementById('sb-search');

  if(GROUP_SECTORS[key]) {
    // ── GROUP sector: show child sector cards ──
    const group = GROUP_SECTORS[key];
    curAssets = [];
    document.getElementById('sb-name').textContent = key;
    document.getElementById('sb-count').textContent = `${group.children.length} sectors`;
    alist.style.display = 'none';
    searchBar.style.display = 'none';
    gview.style.display = 'flex';
    gview.innerHTML = `<div class="group-desc">${group.description}</div>`;
    group.children.forEach((child, i) => {
      const count = (DATA[child] || []).length;
      const card = document.createElement('div');
      card.className = 'child-card';
      card.style.animationDelay = `${i*0.05}s`;
      card.innerHTML = `
        <div class="child-card-left">
          <div class="child-card-name">${child}</div>
          <div class="child-card-count">${count} organization${count!==1?'s':''}</div>
        </div>
        <div class="child-card-arrow">→</div>
      `;
      card.addEventListener('click', () => {
        const regionEl = document.querySelector(`.sr[data-key="${CSS.escape(child)}"]`);
        openSector(child, regionEl);
      });
      gview.appendChild(card);
    });
  } else {
    // ── NORMAL sector: show asset cards ──
    curAssets = DATA[key] || [];
    document.getElementById('sb-name').textContent = key;
    document.getElementById('sb-count').textContent = `${curAssets.length} organization${curAssets.length!==1?'s':''}`;
    gview.style.display = 'none';
    gview.innerHTML = '';
    alist.style.display = 'block';
    searchBar.style.display = 'block';
    document.getElementById('sinput').value = '';
    renderCards(curAssets);
  }

  document.getElementById('sb').classList.add('open');
  document.getElementById('back').style.display = 'flex';
  if(el) zoom(el);
  const label = GROUP_SECTORS[key]
    ? `${GROUP_SECTORS[key].children.length} sectors in ${key}`
    : `${curAssets.length} organizations in ${key}`;
  toast(label);
}

// ═══════════════════════════════════════════════
// ZOOM
// ═══════════════════════════════════════════════
function zoom(el) {
  const outer = document.getElementById('outer');
  const cont  = document.getElementById('container');
  const or = outer.getBoundingClientRect();
  const er = el.getBoundingClientRect();
  const scale = 2.1;
  const ecx = er.left + er.width/2  - or.left;
  const ecy = er.top  + er.height/2 - or.top;
  const tx = (or.width/2  - ecx*scale)/scale;
  const ty = (or.height/2 - ecy*scale)/scale;
  cont.style.transform = `scale(${scale}) translate(${tx}px,${ty}px)`;
}

function reset() {
  const cont = document.getElementById('container');
  cont.style.transform = '';
  document.getElementById('sb').classList.remove('open');
  document.getElementById('back').style.display = 'none';
  document.querySelectorAll('.sr').forEach(r => r.classList.remove('active'));
  document.getElementById('group-view').style.display = 'none';
  document.getElementById('group-view').innerHTML = '';
  document.getElementById('alist').style.display = 'block';
  document.getElementById('sb-search').style.display = 'block';
  active = null;
}

// ═══════════════════════════════════════════════
// RENDER CARDS
// ═══════════════════════════════════════════════
function renderCards(assets) {
  const list = document.getElementById('alist');
  list.innerHTML = '';
  if(!assets.length) {
    list.innerHTML = '<p style="color:var(--muted);font-size:0.78rem;padding:20px;text-align:center">No organizations found.</p>';
    return;
  }
  assets.forEach((a, i) => {
    const c = document.createElement('div');
    c.className = 'card' + (a.link ? '' : ' nolink');
    c.style.animationDelay = `${i*0.035}s`;
    c.innerHTML = `
      <div class="cn">${a.name}</div>
      <div class="cd">${a.description || ''}</div>
      ${a.notes ? '<div class="has-notes">Has notes</div>' : ''}
      ${a.link ? '<div class="clb"><svg viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg></div>' : ''}
    `;
    c.addEventListener('click', () => openModal(a));
    list.appendChild(c);
  });
}

// ═══════════════════════════════════════════════
// FILTER
// ═══════════════════════════════════════════════
function filter(q) {
  q = q.toLowerCase().trim();
  renderCards(q ? curAssets.filter(a =>
    a.name.toLowerCase().includes(q) ||
    (a.description && a.description.toLowerCase().includes(q)) ||
    (a.notes && a.notes.toLowerCase().includes(q))
  ) : curAssets);
}

// ═══════════════════════════════════════════════
// MODAL
// ═══════════════════════════════════════════════
function openModal(a) {
  document.getElementById('mbadge').textContent = active;
  document.getElementById('mname').textContent = a.name;
  document.getElementById('mdesc').textContent = a.description || '';
  const notesWrap = document.getElementById('mnotes-wrap');
  const notesEl   = document.getElementById('mnotes');
  if(a.notes) {
    notesEl.textContent = a.notes;
    notesWrap.style.display = 'block';
  } else {
    notesWrap.style.display = 'none';
  }
  const act = document.getElementById('mact');
  act.innerHTML = a.link
    ? `<a id="mlink" href="${a.link}" target="_blank" rel="noopener noreferrer">Visit Website <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg></a>`
    : `<span id="mnolink">No website available</span>`;
  document.getElementById('mo').classList.add('vis');
}

function closeMo(e) {
  if(!e || e.target===document.getElementById('mo') || e.currentTarget===document.getElementById('mc'))
    document.getElementById('mo').classList.remove('vis');
}

// ═══════════════════════════════════════════════
// TOAST
// ═══════════════════════════════════════════════
function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  clearTimeout(tmr); tmr = setTimeout(()=>t.classList.remove('show'), 2600);
}

document.addEventListener('keydown', e => {
  if(e.key==='Escape') {
    if(document.getElementById('mo').classList.contains('vis')) closeMo({target:document.getElementById('mo')});
    else reset();
  }
});

init();
</script>
